{
  "name": "timber-joint",
  "version": "0.1.0",
  "description": "Structural timber joint designer (EC5)",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "engine:configure": "cmake --preset debug -S engine",
    "engine:build:debug": "cmake --build engine/build/debug",
    "engine:build:release": "cmake --build engine/build/release --config Release",
    "engine:copy": "node scripts/copy-engine.js",
    "setup:engine": "npm run engine:configure && npm run engine:build:debug && npm run engine:copy",
    "package:win": "npm run build && npm run engine:build:release && npm run engine:copy && electron-builder --win",
    "package:linux": "npm run build && npm run engine:build:release && npm run engine:copy && electron-builder --linux",
    "package:mac": "npm run build && npm run engine:build:release && npm run engine:copy && electron-builder --mac"
  },
  "dependencies": {
    "@react-three/drei": "^9.109.0",
    "@react-three/fiber": "^8.17.6",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "immer": "^10.1.1",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.2",
    "three": "^0.168.0",
    "uuid": "^10.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.168.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.4",
    "vite": "^5.4.7"
  },
  "build": {
    "appId": "com.timber-joint.app",
    "productName": "Timber Joint Designer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    }
  }
}
